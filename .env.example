# ----------------------------------------------------------------------------
# Nexoz Digital — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ----------------------------------------------------------------------------

# Resend — transactional email for the contact / lead-magnet form.
# Get a key at https://resend.com/api-keys
# If left empty, the contact form still works but does NOT send email
# (the lead is logged server-side instead). See app/api/contact/route.ts.
RESEND_API_KEY=

# Inbox that receives lead submissions.
CONTACT_TO_EMAIL=hola@nexozdigital.com

# Verified Resend sender. Must be a domain verified in your Resend account.
# Until your domain is verified you can use: onboarding@resend.dev
CONTACT_FROM_EMAIL="Nexoz Digital <onboarding@resend.dev>"
